# ── Database ──────────────────────────────────────────────────────────────────
PESA_DB_PATH=pesa_logger.db

# ── API Security ──────────────────────────────────────────────────────────────
# Required. Set a strong random string before starting the server.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PESA_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
# Bind host: use 127.0.0.1 for local-only, 0.0.0.0 for LAN/Tailscale
PESA_BIND_HOST=127.0.0.1

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: openai | anthropic | ollama | stub
# stub = no AI calls, safe for offline use and testing
AI_PROVIDER=stub

# AI generation settings (apply to all providers)
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.3
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# ── OpenAI (AI_PROVIDER=openai) ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic / Claude (AI_PROVIDER=anthropic) ────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Ollama / Local LLM (AI_PROVIDER=ollama) ───────────────────────────────────
# Install Ollama from https://ollama.ai then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Session security ──────────────────────────────────────────────────────────
# Auto-generated if not set. Set explicitly for stable deployments.
SESSION_SECRET=
SESSION_COOKIE_SECURE=false